# Supabase (V1 frontend runs on synthetic data and does NOT require these to be set).
# Fill these in only when wiring the app to a real Supabase/PostgreSQL+PostGIS backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (never expose to the browser). Used by ingestion scripts.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
